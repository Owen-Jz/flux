{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "fluxboard.site" }],
      "destination": "https://www.fluxboard.site/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fluxboard.site" }],
      "destination": "https://www.fluxboard.site/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-trials",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/check-past-due",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/purge-deleted-workspaces",
      "schedule": "0 2 * * *"
    }
  ]
}
